DATABASE_URL=postgresql+asyncpg://shh_admin:SmartHealthHub@localhost:5445/smarthealthhub
REDIS_URL=redis://redis:6379/0
JWT_SECRET_KEY=<generate-with-openssl-rand-hex-32>
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
QR_HMAC_SECRET=<generate-with-openssl-rand-hex-32>
# Set to your LAN IP + port so QR codes work when scanned by mobile phones on the same Wi-Fi.
# Find your LAN IP: run `ipconfig` (Windows) and look for IPv4 Address.
# Example: QR_BASE_URL=http://192.168.1.100:3000
QR_BASE_URL=http://localhost:3000
SEMAPHORE_API_KEY=<your-semaphore-api-key>
SEMAPHORE_SENDER_NAME=BHC-Health
SEMAPHORE_WEBHOOK_SECRET=<optional-shared-secret-from-semaphore-dashboard>
SMS_REMINDER_LEAD_HOURS=24
SMS_MAX_RETRIES=3
SMS_IMMUNIZATION_LEAD_DAYS=3
ENCRYPTION_KEY=<32-byte-base64-encoded-aes-key>
# Must be a JSON array (pydantic-settings v2 requirement for list fields)
CORS_ORIGINS=["http://localhost:3000"]
